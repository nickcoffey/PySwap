{
  "name": "pyswap",
  "displayName": "PySwap",
  "description": "Quickly swap between Python interpreters from a predefined list, right from the Command Palette. No digging through menus — just pick your snake and go.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pyswap.select",
        "title": "PySwap: Select Python Interpreter from List"
      }
    ],
    "configuration": {
      "title": "PySwap",
      "properties": {
        "pyswap.interpreterPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of Python interpreter paths to choose from."
        }
      }
    }
  },
  "extensionDependencies": [
    "ms-python.python"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
